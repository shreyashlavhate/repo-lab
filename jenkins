pipeline {
agent any
 stages {
  stage('Create build archive build') {
   steps {
    script {
     // Make the output directory.
     sh 'mkdir -p shreya'
     // Write a useful file, which is needed to be archived.
     writeFile file: 'shreya/backup.txt', text: 'Critical Cluster backup. Rollout plan'
       }
    }
   }
   stage('Archive build output') {
    steps {
    // Archive the build output artifacts.
     archiveArtifacts artifacts: 'shreya/*.txt'
     input 'Sure to run the Job ?'
     }
   }
  }
}
